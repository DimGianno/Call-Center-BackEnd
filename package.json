{
    "name": "call-center-backend",
    "version": "1.0.0",
    "description": "DevReady backend project for Call Center",
    "main": "src/index.js",
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "seed": "tsx src/db/seed.ts",
        "backfill:email-verification": "tsx src/db/backfillEmailVerification.ts",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "check": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run test",
        "bench:build": "node scripts/benchmark.mjs script build",
        "bench:typecheck": "node scripts/benchmark.mjs script typecheck",
        "bench:tsc": "node scripts/benchmark.mjs tsc"
    },
    "author": "Dimitrios Giannopoulos",
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.13.3",
        "@types/supertest": "^7.2.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript/native": "npm:typescript@^7.0.2",
        "eslint": "^10.7.0",
        "jest": "^30.4.2",
        "mongodb-memory-server": "^11.2.0",
        "prettier": "^3.9.6",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "tsx": "^4.23.1",
        "typescript": "npm:@typescript/typescript6@^6.0.2",
        "typescript-eslint": "^8.65.0"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "mongodb": "^7.5.0",
        "mongoose": "^9.8.0",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.4.3"
    }
}
